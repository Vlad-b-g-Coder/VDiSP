{
  "version": 2,
  "builds": [
    {
      "src": "server/server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["server/forapi.json"]
      }
    },
    {
      "src": "**/*.{css,html}",
      "use": "@vercel/static"
    },
    {
      "src": "onehotel/**",
      "use": "@vercel/static"
    },
    {
      "src": "*.js",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/styles.css",       "dest": "/styles.css" },
    { "src": "/styleAll.css",     "dest": "/styleAll.css" },
    { "src": "/details.css",      "dest": "/details.css" },
    { "src": "/script.js",        "dest": "/script.js" },
    { "src": "/search-header.js", "dest": "/search-header.js" },
    { "src": "/forapi.json",      "dest": "/server/forapi.json" },
    { "src": "/onehotel/(.*)",    "dest": "/onehotel/$1" },
    { "src": "/(.*)",             "dest": "server/server.js" }
  ]
}